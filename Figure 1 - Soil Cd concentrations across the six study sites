  plot = p_cd_final,
  width = 15, #* aspect_ratio,
  height = 16,
  units = "cm",
  dpi = 600,
  compression = "lzw"
)

cat("\n")
cat("=" %>% rep(80) %>% paste(collapse = ""), "\n")
cat("CADMIUM ANALYSIS COMPLETE!\n")
cat("Figure saved as:", output_file_path, "\n")
