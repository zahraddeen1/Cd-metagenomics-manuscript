# ==============================================================================
# PART B: PLOTTING SECTION (Loading from Saved Excel) — STACKED, EQUAL-SIZE PANELS
# ==============================================================================

required_packages <- c("tidyverse", "readxl", "RColorBrewer", "patchwork")

install_and_load <- function(packages) {
  for (pkg in packages) {
    if (!requireNamespace(pkg, quietly = TRUE)) {
      cat(sprintf("! %s not found. Installing from CRAN...\n", pkg))
      install.packages(pkg, dependencies = TRUE, repos = "https://cloud.r-project.org")
    }
    suppressPackageStartupMessages(library(pkg, character.only = TRUE))
    cat(sprintf("  - %s loaded\n", pkg))
  }
}

install_and_load(required_packages)

# 1. SETUP DIRECTORIES & FILE PATHS
output_dir <- "C:/obj2_dataset/Results_new"
input_file <- "C:/obj2_dataset/Results/ANCOM_taxonomy_advanced/ANCOMBC_Final_Elaborate.xlsx"

if (!dir.exists(output_dir)) dir.create(output_dir, recursive = TRUE)

# Consistent Aesthetic Constants
PUB_FONT    <- "Helvetica"
GLOBAL_SIZE <- 20
BORDER_COL  <- "#333333"

# How many "row slots" every panel should reserve on the taxon axis.
# This is what keeps panel HEIGHT identical across kingdoms even when
# a kingdom has fewer than 20 significant/plotted taxa.
N_SLOTS <- 20

# 2. DATA PREP FUNCTION (separated from plotting so we can compute a
#    shared color palette / legend structure if desired, and so each
#    plot object can be returned rather than saved individually)
prep_data <- function(kingdom_name, excel_path) {
  dat_all <- read_excel(excel_path, sheet = kingdom_name)
  
  dat_all <- dat_all %>%
    mutate(across(c(log_fold_change, ci.lo.adj, ci.up.adj),
                  ~ as.numeric(gsub(",", ".", as.character(.)))))
  
  dat.fig <- dat_all %>%
    mutate(abs_lfc = abs(log_fold_change)) %>%
    arrange(significance == "ns", desc(abs_lfc)) %>%
    slice_head(n = N_SLOTS)
  
  target_order <- sort(unique(dat.fig$taxon))
  
  # --- KEY FIX FOR EQUAL PANEL HEIGHT ---
  # Pad the factor levels out to N_SLOTS with invisible placeholder
  # levels. The discrete axis then always has the same number of
  # levels across all three kingdoms, so coord_flip()'s panel height
  # (in a fixed-aspect / patchwork-aligned layout) stays identical,
  # regardless of how many real taxa a given kingdom has.
  n_real <- length(target_order)
  if (n_real < N_SLOTS) {
    placeholder_levels <- paste0(".pad_", seq_len(N_SLOTS - n_real))
    full_levels <- c(target_order, placeholder_levels)
  } else {
    full_levels <- target_order
  }
  
  dat.fig$taxon_clean <- factor(dat.fig$taxon, levels = rev(full_levels))
  
  list(dat.fig = dat.fig, target_order = target_order, full_levels = full_levels)
}

# 3. PLOTTING FUNCTION — returns a ggplot object (no saving here)
#    Every panel always draws its own x-axis tick labels (the LFC
#    numbers), but the x-axis TITLE ("Log Fold Change") can be
#    suppressed per panel via show_axis_title — used so only the
#    bottom-most plot in the stack carries the title.
build_plot <- function(kingdom_name, prep, show_axis_title = TRUE) {
  
  dat.fig       <- prep$dat.fig
  target_order  <- prep$target_order
  full_levels   <- prep$full_levels
  
  p <- ggplot(dat.fig,
              aes(x = taxon_clean,
                  y = log_fold_change,
                  fill = taxon_clean)) +
    
    geom_bar(
      stat = "identity",
      width = 0.8,
      color = BORDER_COL
    ) +
    
    geom_errorbar(
      aes(ymin = ci.lo.adj,
          ymax = ci.up.adj),
      width = 0.3
    ) +
    
    geom_text(
      aes(
        y = ifelse(
          log_fold_change > 0,
          ci.up.adj + 0.3,
          ci.lo.adj - 0.3
        ),
        label = significance,
        fontface = ifelse(significance == "ns", "italic", "bold")
      ),
      size = 7
    ) +
    
    geom_hline(
      yintercept = 0,
      linetype = "dashed",
      color = BORDER_COL
    ) +
    
    # Each kingdom keeps its OWN y-range here — this is what preserves
    # each plot's unique CIs / reference points without forcing them
    # to align across panels.
    scale_y_continuous(
      expand = expansion(mult = c(0.05, 0.05))
    ) +
    
    # drop = FALSE keeps the padded placeholder levels reserved as
    # empty space on the axis, even though nothing is drawn for them.
    scale_x_discrete(drop = FALSE) +
    
    scale_fill_manual(
      values = grDevices::colorRampPalette(
        brewer.pal(12, "Paired")
      )(length(target_order)),
      name = "Genus",
      breaks = target_order,
      labels = gsub("_", " ", target_order),
      na.translate = FALSE   # placeholder levels never get a fill value -> no legend entries
    ) +
    
    labs(
      x = NULL,
      y = "Log Fold Change",
      #title = sprintf("%s: Differential Abundance", kingdom_name)
    ) +
    
    coord_flip(clip = "off") +
    
    theme_bw(base_size = GLOBAL_SIZE) +
    
    theme(
      text = element_text(family = PUB_FONT),
      
      axis.title = element_text(face = "bold", size = GLOBAL_SIZE + 5),
      
      axis.text.x = element_text(color = "black", size = GLOBAL_SIZE + 5),
      axis.title.x = if (show_axis_title) {
        element_text(face = "bold", size = GLOBAL_SIZE + 5)
      } else {
        element_blank()
      },
      axis.ticks.x = element_line(),
      
      axis.text.y = element_blank(),
      axis.ticks.y = element_blank(),
      
      # Identical, fixed-thickness border on every panel -> when
      # stacked, the black rectangles line up with no staggering.
      panel.border = element_rect(color = BORDER_COL, linewidth = 1, fill = NA),
      
      panel.grid.minor = element_blank(),
      
      legend.title = element_text(face = "bold", size = GLOBAL_SIZE + 5, hjust = 0),
      legend.text = element_text(
        face = "italic",
        size = GLOBAL_SIZE + 5,
        margin = margin(t = 4, b = 4, l = 6),
        hjust = 0
      ),
      legend.key.size   = unit(1.2, "cm"),
      legend.key.height = unit(1.2, "cm"),
      legend.spacing.y  = unit(0.4, "cm"),
      legend.position   = "right",
      # Left-justify the legend block within its gutter (instead of the
      # default center) so the left edge of every panel's legend lines
      # up at the same horizontal position when the plots are stacked.
      legend.justification = "left",
      
      plot.margin = margin(20, 20, 20, 20, unit = "pt")
    ) +
    
    guides(fill = guide_legend(ncol = 1, byrow = TRUE))
  
  p
}

# 4. EXECUTION
if (file.exists(input_file)) {
  
  kingdoms <- intersect(excel_sheets(input_file), c("Archaea", "Bacteria", "Fungi"))
  # enforce desired stacking order regardless of sheet order in the file
  kingdoms <- kingdoms[match(c("Archaea", "Bacteria", "Fungi"), kingdoms)]
  kingdoms <- kingdoms[!is.na(kingdoms)]
  
  preps <- lapply(kingdoms, prep_data, excel_path = input_file)
  names(preps) <- kingdoms
  
  # Every panel keeps its own x-axis tick labels (each kingdom has a
  # different LFC scale) and its own legend. Only the bottom-most
  # panel (last in the stacking order) keeps the x-axis TITLE.
  plots <- lapply(seq_along(kingdoms), function(i) {
    build_plot(
      kingdoms[i],
      preps[[kingdoms[i]]],
      show_axis_title = (i == length(kingdoms))
    )
  })
  names(plots) <- kingdoms
  
  # 5. COMBINE — patchwork stacks vertically and aligns panel widths
  #    automatically. heights = "1" each forces identical panel HEIGHT
  #    too, since the taxon axis now has the same N_SLOTS levels in
  #    every plot.
  #
  #    NOTE: guides are NOT collected here. Each plot keeps its own
  #    legend, and patchwork's default behaviour centers a panel's
  #    legend vertically against that panel (not the full stack), so
  #    each legend sits aligned with its own kingdom's plot. With
  #    legend.justification = "left" set above, all three legends are
  #    now also left-aligned with one another (same left edge),
  #    matching the equal-size panel alignment.
  combined <- wrap_plots(plots, ncol = 1, heights = rep(1, length(plots)))
  
  ggsave(
    file.path(output_dir, "plot_stacked_archaea_bacteria_fungi.tiff"),
    plot = combined,
    device = "tiff",
    width = 16,
    height = 12 * length(plots),   # scale canvas height to number of stacked panels
    dpi = 600,
    compression = "lzw",
    limitsize = FALSE
  )
  
  cat("\nStacked plot saved to:", file.path(output_dir, "plot_stacked_archaea_bacteria_fungi.tiff"), "\n")
  
} else {
  stop("Input file not found at: ", input_file)
}
