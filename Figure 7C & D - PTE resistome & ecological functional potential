message("\n── Part A: Heavy Metal Resistome ──────────────────────────────────────")

set.seed(123)

# A1. Load ─────────────────────────────────────────────────────────────────────
COLS <- c("Bin","Query","Subject","Identity","Align_len","Mismatch",
          "Gap","Qstart","Qend","Sstart","Send","Evalue","Bitscore")

df_raw <- read_tsv(BACMET_FILE, col_names = COLS, show_col_types = FALSE) |>
  filter(!is.na(Evalue), Bin != "Bin_ID")

# A2. Filter ───────────────────────────────────────────────────────────────────
df_clean <- df_raw |>
  mutate(
    Align_Continuity = Align_len / (abs(Send - Sstart) + 1),
    Gene_Name = sapply(strsplit(Subject, "\\|"),
                       \(x) if (length(x) >= 2) x[2] else NA_character_)
  ) |>
  filter(!is.na(Gene_Name),
         Evalue < 1e-20,
         Identity > 30,
         Align_Continuity > 0.8)

# A3. Gene → metal category ────────────────────────────────────────────────────
gene_category_map <- list(
  "Copper (Cu)"      = c("copA","copB","copR","copS","pcoR"),
  "Arsenic (As)"     = c("arsA","arsC","arsM","arsT"),
  "Mercury (Hg)"     = c("merA"),
  "Co/Zn/Cd"         = c("czcD","pbrA","tcrA"),
  "Nickel/Cobalt"    = c("nikB","nikC","nikD","nikE","nikR","rcnA/yohM"),
  "Chromium (Cr)"    = c("chrA","chrA1","chrB1","chrF"),
  "Tellurium (Te)"   = c("terC"),
  "Zinc (Zn)"        = c("znuC/yebM","zipB"),
  "Iron (Fe)"        = c("fbpB","fbpC","sitB","sitD","yfeB","yfeC"),
  "Manganese (Mn)"   = c("mntH/yfeP","mntR"),
  "Molybdenum (Mo)"  = c("modA","modB","modC"),
  "Phosphate (P)"    = c("pstA","pstB","pstC","pstS"),
  "Multidrug Efflux" = c("acrC","emrBsm","mdtA/yegM","mdtB/yegN","mdtC",
                         "smeD","smeF","smrA","sugE")
)

map_df <- stack(gene_category_map) |>
  setNames(c("Gene_Name","Category")) |>
  mutate(across(everything(), as.character))

df_full <- df_clean |>
  left_join(map_df, by = "Gene_Name") |>
