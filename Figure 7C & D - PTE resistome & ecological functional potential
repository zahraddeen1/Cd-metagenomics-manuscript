  height               = nrow(mat_z) * unit(CELL_MM, "mm"),
  cluster_rows         = TRUE,
  cluster_columns      = TRUE,
  row_dend_gp          = gpar(lwd = DEND_LWD),
  column_dend_gp       = gpar(lwd = DEND_LWD),
  row_names_gp = gpar(
    fontsize = LABEL_PT + 3,
    fontface = "plain",
    fontfamily = PUB_FONT,
    col = "black"
  ),
  column_names_gp = gpar(
    fontsize = LABEL_PT + 3,
    fontface = "plain",
    fontfamily = PUB_FONT,
    col = "black"
  ),
  rect_gp              = gpar(col = GRID_COL, lwd = GRID_LWD),
  border               = TRUE,
  border_gp            = gpar(col = BORDER_COL, lwd = 0.8),
  #column_title         = "Ecological Functional Potential",
  column_title_gp = gpar(
    fontsize = TITLE_PT,
    fontface = "bold",
    fontfamily = PUB_FONT,
    col = "black"
  ),
  heatmap_legend_param = hm_legend_params
