MAG_MAP <- data.frame(
  Bin = c("BG06_bin.3","TS03_bin.1","TS01_bin.2","BM04_bin.5",
          "BM02_bin.2","BM04_bin.4","TD02_bin.3","BM01_bin.6","BM05_bin.5"),
  MAG = paste0("MAG ", 1:9),
  stringsAsFactors = FALSE
)

relabel_bins <- function(x) {
  idx <- match(x, MAG_MAP$Bin)
  ifelse(!is.na(idx), MAG_MAP$MAG[idx], x)
}

# ══════════════════════════════════════════════════════════════════════════════
# 5.  EXPORT HELPER
# ══════════════════════════════════════════════════════════════════════════════
# mat      – matrix (used only for dimension calculation)
# ht_obj   – ComplexHeatmap object
# filename – base name, no extension
# pad_mm   – c(bottom, left, top, right)
export_tiff <- function(mat, ht_obj, filename, pad_mm = c(15, 20, 15, 20)) {
  w_mm <- max(ncol(mat) * CELL_MM + pad_mm[2] + pad_mm[4] + 45, 89)
  h_mm <- nrow(mat) * CELL_MM + pad_mm[1] + pad_mm[3] + 30
  path <- file.path(OUTPUT_DIR, paste0(filename, ".tiff"))
  agg_tiff(path, width = w_mm, height = h_mm,
           units = "mm", res = 600, compression = "lzw")
  draw(ht_obj, padding = unit(pad_mm, "mm"))
  dev.off()
  message("  ✔ Saved → ", path)
}

