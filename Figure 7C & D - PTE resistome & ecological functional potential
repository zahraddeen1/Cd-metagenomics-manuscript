  count(Gene_Name) |>
  filter(n >= ceiling(0.1 * n_bins)) |>
  pull(Gene_Name)

df_core <- filter(df_full, Gene_Name %in% core_genes)

# A5. Matrix (genes × MAGs, log10 bitscore) ───────────────────────────────────
build_hmr_mat <- function(df) {
  wide <- df |>
    group_by(Bin, Gene_Name) |>
    summarise(Score = max(Bitscore), .groups = "drop") |>
    pivot_wider(names_from = Gene_Name, values_from = Score)
  mat           <- as.matrix(wide[, -1])
  rownames(mat) <- wide$Bin
  mat_log       <- log10(mat)
  mat_log[is.infinite(mat_log)] <- NA
  t(mat_log)      # genes as rows, MAGs as columns
}

cluster_mat <- function(mat) {
  imp <- mat; imp[is.na(imp)] <- 0
  list(row = hclust(dist(imp),    method = "ward.D2"),
       col = hclust(dist(t(imp)), method = "ward.D2"))
}

# A6. Heatmap builder ──────────────────────────────────────────────────────────
hmr_heatmap <- function(mat, clust, df_src, title) {
  colnames(mat) <- relabel_bins(colnames(mat))
  
  anno_df <- df_src |>
    distinct(Gene_Name, Category) |>
    filter(Gene_Name %in% rownames(mat)) |>
    arrange(match(Gene_Name, rownames(mat)))
  
  cats       <- sort(unique(df_src$Category))
  cat_colors <- setNames(qualitative_hcl(length(cats), palette = "Dark 3"), cats)
  
  row_ha <- rowAnnotation(
    Category = anno_df$Category,
    col      = list(Category = cat_colors),
    show_annotation_name    = FALSE,
    simple_anno_size        = unit(3, "mm"),
    gp                      = gpar(col = GRID_COL, lwd = GRID_LWD),
    annotation_legend_param = list(Category = annot_legend_params)
  )
  
  q      <- quantile(mat, c(0.05, 0.5, 0.95), na.rm = TRUE)
  col_fn <- colorRamp2(q, c(HM_LOW, HM_MID, HM_HIGH))
  
  Heatmap(
    mat,
    name                 = "log\u2081\u2080(bitscore)",
    col                  = col_fn,
    na_col               = "#F5F5F5",
    width                = ncol(mat) * unit(CELL_MM, "mm"),
    height               = nrow(mat) * unit(CELL_MM, "mm"),
    cluster_rows         = clust$row,
    cluster_columns      = clust$col,
    left_annotation      = row_ha,
    row_dend_gp          = gpar(lwd = DEND_LWD),
    column_dend_gp       = gpar(lwd = DEND_LWD),
    row_names_gp = gpar(
      fontsize = LABEL_PT + 3,
      fontface = "italic",
      fontfamily = PUB_FONT,
      col = "black"
    ),
    column_names_gp = gpar(
      fontsize = LABEL_PT +3,
      fontface = "plain",
      fontfamily = PUB_FONT,
      col = "black"
    ),
    rect_gp              = gpar(col = GRID_COL, lwd = GRID_LWD),
    border               = TRUE,
    border_gp            = gpar(col = BORDER_COL, lwd = 0.8),
    column_title         = title,
    column_title_gp = gpar(
      fontsize = TITLE_PT + 3,
      fontface = "bold",
      fontfamily = PUB_FONT,
      col = "black"
    ),
    heatmap_legend_param = hm_legend_params
  )
}

# A7. Build & export ───────────────────────────────────────────────────────────
mat_full  <- build_hmr_mat(df_full);  clust_full <- cluster_mat(mat_full)
mat_core  <- build_hmr_mat(df_core);  clust_core <- cluster_mat(mat_core)

