message("\n── Part B: Ecological Functional Potential ────────────────────────────")

set.seed(42)

# B1. Load ─────────────────────────────────────────────────────────────────────
metab <- read_tsv(METAB_FILE, show_col_types = FALSE)

# B2. Functional classification ────────────────────────────────────────────────
FUNC_RULES <- tribble(
  ~col,          ~pattern,                          ~Function,
  "db_can_hmm",  "^GH.*cellulose|glucan",           "Cellulose degradation",
  "db_can_hmm",  "^GH.*xylan",                      "Hemicellulose degradation",
  "db_can_hmm",  "^GH.*chitin",                     "Chitin degradation",
  "db_can_hmm",  "^GH.*mannan",                     "Mannan degradation",
  "db_can_hmm",  "^PL",                             "Pectin/alginate degradation",
  "db_can_hmm",  "^GT",                             "Polysaccharide biosynthesis",
  "db_can_hmm",  "^AA",                             "Oxidative enzymes",
  "KO_definition","trehalase|trehalose",            "Trehalose metabolism",
  "KO_definition","oxidoreductase|dehydrogenase",   "Redox metabolism",
  "KO_definition","peptidoglycan",                  "Cell wall metabolism",
  "KO_definition","glycosyltransferase",            "Cell surface modification",
  "KO_definition","glycine betaine|osmotic",        "Osmotic stress",
  "KO_definition","deacetylase|esterase",           "Detoxification"
)

metab$Function <- NA_character_
for (i in seq_len(nrow(FUNC_RULES))) {
  r   <- FUNC_RULES[i, ]
  tgt <- metab[[r$col]]
  hit <- !is.na(tgt) & str_detect(tgt, regex(r$pattern, ignore_case = TRUE))
  metab$Function[is.na(metab$Function) & hit] <- r$Function
}
metab$Function[is.na(metab$Function) & !is.na(metab$KO) & metab$KO == "K00368"] <- "Nitrogen metabolism"

# B3. Bin → MAG renaming ───────────────────────────────────────────────────────
relabel_bin_id <- function(x) {
  case_when(
    str_detect(x, "BG06")                           ~ "MAG 1",
    str_detect(x, "TS03")                           ~ "MAG 2",
    str_detect(x, "TS01")                           ~ "MAG 3",
    str_detect(x, "BM04") & str_detect(x, "bin.5") ~ "MAG 4",
    str_detect(x, "BM02")                           ~ "MAG 5",
    str_detect(x, "BM04") & str_detect(x, "bin.4") ~ "MAG 6",
    str_detect(x, "TD02")                           ~ "MAG 7",
    str_detect(x, "BM01")                           ~ "MAG 8",
    str_detect(x, "BM05")                           ~ "MAG 9",
    TRUE                                             ~ x
  )
}

# B4. Matrix (MAGs × functions, z-score) ───────────────────────────────────────
hm_df <- metab |>
  filter(!is.na(Function)) |>
  mutate(Bin_ID = relabel_bin_id(Bin_ID)) |>
  count(Bin_ID, Function) |>
  pivot_wider(names_from = Function, values_from = n, values_fill = 0L)

mat_ecol           <- as.matrix(hm_df[, -1])
rownames(mat_ecol) <- hm_df$Bin_ID
mat_z              <- t(scale(t(mat_ecol)))   # row-wise z-score

# B5. Heatmap ──────────────────────────────────────────────────────────────────
col_fn_z <- colorRamp2(
