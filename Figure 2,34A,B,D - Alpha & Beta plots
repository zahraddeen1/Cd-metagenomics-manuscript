PUB_FONT   <- "Helvetica"
BASE_PT    <- 20
BORDER_COL <- "#333333"
LINE_WD    <- 0.8

theme_publication <- function(base_size = BASE_PT) {
  
  theme_bw(base_size = base_size) +
    
    theme(
      text = element_text(
        family = PUB_FONT,
        colour = "black"
      ),
      
      plot.title = element_text(
        family = PUB_FONT,
        face = "bold",
        colour = "black",
        size = rel(1.1)
      ),
      
      axis.title = element_text(
        family = PUB_FONT,
        face = "bold",
        colour = "black"
      ),
      
      axis.text = element_text(
        family = PUB_FONT,
        colour = "black"
      ),
      
      legend.title = element_text(
        family = PUB_FONT,
        face = "bold",
        colour = "black"
      ),
      
      legend.text = element_text(
        family = PUB_FONT,
        colour = "black"
      ),
      
      strip.text = element_text(
        family = PUB_FONT,
        face = "bold",
        colour = "black"
      ),
      
      # Match Cd figure style
      panel.grid.minor = element_blank(),
      
      panel.border = element_rect(
        colour = BORDER_COL,
        fill = NA,
        linewidth = LINE_WD
      ),
      
      axis.ticks = element_line(
        colour = BORDER_COL,
        linewidth = LINE_WD
      )
    )
}

