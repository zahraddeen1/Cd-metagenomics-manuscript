load_cache <- function(domain_name) {
  cache_path <- file.path(output_dir, tolower(domain_name), "cache",
                          paste0(domain_name, "_analysis_cache.rds"))
  if (!file.exists(cache_path)) {
    cat(sprintf("  ⊗ Cache not found for %s: %s\n", domain_name, cache_path))
    return(NULL)
  }
  res <- readRDS(cache_path)
  cat(sprintf("  ✓ %s cache loaded\n", domain_name))
  res
}

